# Backend
DATABASE_URL=sqlite:///./backend/app.db
V2_CONTROL_PLANE_ENABLED=true
V2_AGENT_RUNTIME_ENABLED=true
V2_REAL_AI_WORKER_ENABLED=false
V2_CODEX_PROVIDER_ENABLED=false

# Optional AI provider keys
OPENAI_API_KEY=<set-if-needed>
DEEPSEEK_API_KEY=<set-if-needed>

# Local runtime overrides
AI_FACTORY_RUNTIME_DIR=<optional-path>
EXECUTOR_SANDBOX_ROOT=<optional-path>

# Codex provider settings
CODEX_DIAGNOSTICS_DIR=<optional-path>
CODEX_THREAD_ID=
CODEX_MANAGED_BY_NPM=
